# Meta-Learning System — AKMS Configuration
#
# Expert + Librarian use claude_cli: runs `claude -p` as a subprocess.
# No API key needed — uses your existing Claude subscription auth.
#
# To migrate Expert to a self-hosted model on RunPod:
#   1. Add a runpod provider block with your pod's base_url
#   2. Change agent_assignments.expert.provider to runpod

providers:
  claude_cli:
    models:
      - claude-opus-4-6

  # Uncomment when RunPod is ready:
  # runpod:
  #   base_url: "https://<your-pod-id>.proxy.runpod.net"
  #   models:
  #     - <your-model-name>

agent_assignments:
  expert:    { provider: claude_cli, model: claude-opus-4-6 }
  librarian: { provider: claude_cli, model: claude-opus-4-6 }

knowledge:
  graph_dir: "knowledge/graph"
  archives_dir: "knowledge/archives"
  logs_dir: "knowledge/logs"
  db_path: "knowledge/akms.db"

expert:
  token_threshold: 50000
